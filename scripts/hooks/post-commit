#!/bin/bash
# post-commit: bump version based on conventional commit type, then amend it in.
#
# Bump rules (Conventional Commits):
#   feat!: / BREAKING CHANGE  → major  (x.0.0)
#   feat:                     → minor  (0.x.0)
#   everything else           → patch  (0.0.x)

SENTINEL=".git/BUMP_IN_PROGRESS"

# Guard against recursion: the --amend below triggers post-commit again.
if [ -f "$SENTINEL" ]; then
    rm -f "$SENTINEL"
    exit 0
fi

PACKAGE_JSON="package.json"

MSG=$(git log -1 --pretty=%s)

# Determine bump type
if echo "$MSG" | grep -qE "!:|BREAKING CHANGE"; then
    BUMP="major"
elif echo "$MSG" | grep -qE "^feat(\(.+\))?:"; then
    BUMP="minor"
else
    BUMP="patch"
fi

# Read current version from package.json
CURRENT=$(grep '"version"' "$PACKAGE_JSON" | head -1 | sed 's/.*"version": "\([^"]*\)".*/\1/')

if [ -z "$CURRENT" ]; then
    echo "post-commit: could not read version, skipping bump"
    exit 0
fi

IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT"

case "$BUMP" in
    major) MAJOR=$((MAJOR + 1)); MINOR=0; PATCH=0 ;;
    minor) MINOR=$((MINOR + 1)); PATCH=0 ;;
    patch) PATCH=$((PATCH + 1)) ;;
esac

NEW="$MAJOR.$MINOR.$PATCH"
echo "post-commit: $BUMP bump  $CURRENT → $NEW"

# Update package.json
sed -i "s/\"version\": \"$CURRENT\"/\"version\": \"$NEW\"/" "$PACKAGE_JSON"

# Create sentinel before amending so the re-triggered hook exits cleanly.
touch "$SENTINEL"

git add "$PACKAGE_JSON"
git commit --amend --no-edit
